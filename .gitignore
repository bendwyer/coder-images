# Composed from github/gitignore Global templates, tailored for a repo of
# Dockerfiles + CI config (no build artifacts are committed; images build in CI).

# macOS (github/gitignore Global/macOS)
.DS_Store
.localized
__MACOSX/
.AppleDouble
.LSOverride
Icon?
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.com.apple.timemachine.supported
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Linux (github/gitignore Global/Linux)
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*
nohup.out

# Windows (github/gitignore Global/Windows)
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Local secrets / environment
.env
*.env
.envrc
